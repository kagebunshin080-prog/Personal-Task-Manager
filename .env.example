# Railway sets DATABASE_URL automatically when you attach a Postgres plugin.
# For local development only, point this at a local/dev Postgres instance.
DATABASE_URL=postgres://user:password@localhost:5432/taskflow

# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Comma-separated list of frontend origins allowed to call this API.
# Use * during setup/testing, then lock it down once you know your real
# GitHub Pages / production URL.
ALLOWED_ORIGINS=*

PORT=3000
